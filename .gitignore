# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Learn Language with Pronunciation
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Node modules ──────────────────────────────────────────────────────────────
node_modules/
server/node_modules/
client/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
client/dist/
client/build/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Coverage & Testing ────────────────────────────────────────────────────────
coverage/
.nyc_output/
